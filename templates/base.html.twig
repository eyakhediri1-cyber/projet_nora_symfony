<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>{% block title %}🎉 Les 2 Mousquetaires - Événements{% endblock %}</title>
        
        <link rel="stylesheet" href="{{ asset('assets/bootstrap/css/bootstrap.min.css') }}">        
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,100..1000&family=Jost:ital,wght@0,100..900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
        <link rel="stylesheet" href="{{ asset('assets/fonts/font-awesome.min.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/fonts/themify-icons.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/owlcarousel/css/owl.carousel.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/owlcarousel/css/owl.theme.css') }}">  
        <link rel="stylesheet" href="{{ asset('assets/css/jquery-simple-mobilemenu.css') }}">           
        <link rel="stylesheet" href="{{ asset('assets/css/magnific-popup.css') }}">     
        <link rel="stylesheet" href="{{ asset('assets/css/animate.css') }}">    
        <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

        {% block stylesheets %}{% endblock %}
        {{ importmap('app') }}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>

    <body>
        <div class="preloaders">
            <span class="loader"></span>
        </div>

        <div id="navigation" class="navbar-light bg-faded site-navigation">
            <div class="container-fluid">
                <div class="row">

                    <div class="col-20 align-self-center">
                        <div class="site-logo">
                            <a href="{{ path('app_accueil') }}">
                                <img src="{{ asset('assets/img/nora.png') }}" alt="Logo">
                            </a>                       
                        </div>
                    </div>
                    
                    <div class="col-60 d-flex">
                        <nav id="main-menu">
                            <ul>
                                <li>
                                    <a href="{{ path('app_accueil') }}" class="{{ app.request.get('_route') == 'app_accueil' ? 'active' : '' }}">
                                        🏠 Accueil
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_evenements') }}" class="{{ app.request.get('_route') starts with 'app_evenement' ? 'active' : '' }}">
                                        📅 Événements
                                    </a>
                                </li>
                                {% if is_granted('ROLE_ORGANISATEUR') %}
                                <li>
                                    <a href="{{ path('app_evenement_nouveau') }}" class="{{ app.request.get('_route') == 'app_evenement_nouveau' ? 'active' : '' }}">
                                        ➕ Créer
                                    </a>
                                </li>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                <li>
                                    <a href="{{ path('app_lieux') }}" class="{{ app.request.get('_route') starts with 'app_lieu' ? 'active' : '' }}">
                                        📍 Lieux
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_tags') }}" class="{{ app.request.get('_route') starts with 'app_tag' ? 'active' : '' }}">
                                        🏷️ Tags
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_users') }}" style="color: #d9534f;">
                                        ⚙️ Administration
                                    </a>
                                </li>
                                {% endif %}
                            </ul>
                        </nav>
                    </div>
                    
                    <div class="col-20 d-none d-xl-block text-end align-self-center">
                        {% if app.user %}
                            <div class="dropdown d-inline-block">
                                <button class="btn_one dropdown-toggle" type="button" id="userMenu" 
                                        data-bs-toggle="dropdown" aria-expanded="false" 
                                        style="padding: 10px 25px; border-radius: 50px;">
                                    <i class="ti-user me-2"></i>{{ app.user.pseudo }}
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <span class="badge bg-danger ms-1" style="font-size: 10px;">ADMIN</span>
                                    {% elseif is_granted('ROLE_ORGANISATEUR') %}
                                        <span class="badge bg-success ms-1" style="font-size: 10px;">ORGA</span>
                                    {% else %}
                                        <span class="badge bg-primary ms-1" style="font-size: 10px;">USER</span>
                                    {% endif %}
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" aria-labelledby="userMenu">
                                    <li class="px-3 py-2 border-bottom">
                                        <small class="text-muted d-block">Connecté en tant que</small>
                                        <span class="fw-bold">{{ app.user.email }}</span>
                                        <br>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <span class="badge bg-danger mt-1">Administrateur</span>
                                        {% elseif is_granted('ROLE_ORGANISATEUR') %}
                                            <span class="badge bg-success mt-1">Organisateur</span>
                                        {% else %}
                                            <span class="badge bg-primary mt-1">Utilisateur</span>
                                        {% endif %}
                                    </li>
                                    {% if is_granted('ROLE_ORGANISATEUR') %}
                                    <li>
                                        <a class="dropdown-item py-2" href="{{ path('app_evenement_nouveau') }}">
                                            <i class="ti-plus me-2 text-success"></i>Créer un événement
                                        </a>
                                    </li>
                                    {% endif %}
                                    {% if is_granted('ROLE_ADMIN') %}
                                    <li>
                                        <a class="dropdown-item py-2" href="{{ path('app_admin_users') }}">
                                            <i class="ti-settings me-2 text-danger"></i>Gérer les utilisateurs
                                        </a>
                                    </li>
                                    {% endif %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger" href="{{ path('app_logout') }}">
                                            <i class="ti-power-off me-2"></i>Déconnexion
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="header-btn" style="text-decoration: none;">
                                Connexion
                            </a>
                            <a href="{{ path('app_register') }}" class="btn_one" style="text-decoration: none; border-radius: 50px;">
                                S'inscrire
                            </a>
                        {% endif %}
                    </div>
                    
                    <ul class="mobile_menu">                        
                        <li><a href="{{ path('app_accueil') }}">🏠 Accueil</a></li>
                        <li><a href="{{ path('app_evenements') }}">📅 Événements</a></li>
                        {% if is_granted('ROLE_ORGANISATEUR') %}
                        <li><a href="{{ path('app_evenement_nouveau') }}">➕ Créer</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li><a href="{{ path('app_lieux') }}">📍 Lieux</a></li>
                        <li><a href="{{ path('app_tags') }}">🏷️ Tags</a></li>
                        <li><a href="{{ path('app_admin_users') }}" style="color: #d9534f;">⚙️ Administration</a></li>
                        {% endif %}
                        <hr>
                        {% if app.user %}
                            <li class="px-3 py-2 text-muted small">
                                👤 {{ app.user.pseudo }}
                            </li>
                            <li><a href="{{ path('app_logout') }}" class="text-danger">🚪 Déconnexion</a></li>
                        {% else %}
                            <li><a href="{{ path('app_login') }}">🔑 Connexion</a></li>
                            <li><a href="{{ path('app_register') }}">📝 S'inscrire</a></li>
                        {% endif %}
                    </ul>           
                </div>
            </div>
        </div>    

        <main style="padding-top: 120px; min-height: 75vh;">
            <div class="container">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show rounded-4 shadow-sm mb-4 border-0" role="alert">
                            <div class="d-flex align-items-center">
                                <i class="ti-{{ label == 'success' ? 'check' : 'info-alt' }} me-3" style="font-size: 1.2rem;"></i>
                                <div>{{ message }}</div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
                {% block body %}{% endblock %}
            </div>
        </main>

        <footer class="footer_area" style="background-color: #1a1a1a; color: white; padding: 60px 0 30px;">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-sm-6">
                        <div class="single_footer">
                            <img src="{{ asset('assets/img/logo.png') }}" alt="Logo" class="mb-3">
                            <p>Les 2 Mousquetaires : La passion rencontre l'organisation pour des événements inoubliables.</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6">
                        <div class="single_footer">
                            <h4>Explorer</h4>
                            <ul class="list-unstyled">
                                <li><a href="{{ path('app_accueil') }}" class="text-white-50">Accueil</a></li>
                                <li><a href="{{ path('app_evenements') }}" class="text-white-50">Événements</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6">
                        <div class="single_footer">
                            <h4>Contact</h4>
                            <p><i class="ti-email me-2 text-primary"></i> contact@2mousquetaires.tn</p>
                            <p><i class="ti-location-pin me-2 text-primary"></i> Tunis, Tunisie</p>
                        </div>
                    </div>
                </div>
                <div class="row mt-5 pt-4 border-top border-secondary">
                    <div class="col-12 text-center">
                        <p class="mb-0 text-white-50">
                            &copy; {{ "now"|date("Y") }} Les 2 Mousquetaires. Made with 💙 by Eya.
                        </p>
                    </div>
                </div>
            </div>
        </footer>

        <script src="{{ asset('assets/js/jquery-1.12.4.min.js') }}"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset('assets/js/modernizr-2.8.3.min.js') }}"></script>
        <script src="{{ asset('assets/js/jquery-simple-mobilemenu.js') }}"></script>
        <script src="{{ asset('assets/owlcarousel/js/owl.carousel.min.js') }}"></script>
        <script src="{{ asset('assets/js/jquery.magnific-popup.min.js') }}"></script>
        <script src="{{ asset('assets/js/jquery.inview.min.js') }}"></script>
        <script src="{{ asset('assets/js/scrolltopcontrol.js') }}"></script>
        <script src="{{ asset('assets/js/wow.min.js') }}"></script>
        <script src="{{ asset('assets/js/scripts.js') }}"></script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>