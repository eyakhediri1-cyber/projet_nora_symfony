{% extends 'base.html.twig' %}

{% block title %}📝 S'inscrire : {{ evenement.titre }} - Les 2 Mousquetaires{% endblock %}

{% block body %}
    <section class="section-padding">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    
                    {# --- PETITE SÉCURITÉ SUPPLÉMENTAIRE --- #}
                    {% if app.user == evenement.organisateur %}
                        <div class="alert alert-warning rounded-4 p-4 shadow-sm text-center">
                            <h4>🚫 Action impossible</h4>
                            <p>Vous ne pouvez pas vous inscrire à un événement que vous organisez vous-même.</p>
                            <a href="{{ path('app_evenement_detail', {id: evenement.id}) }}" class="btn_one mt-3">Retour au détail</a>
                        </div>
                    {% else %}

                        <div class="section-title text-center">
                            <h2>📝 S'inscrire à l'<b>événement</b></h2>
                            <p>Confirmez votre participation à cet événement exceptionnel.</p>
                        </div>

                        {# --- RÉCAPITULATIF DE L'ÉVÉNEMENT --- #}
                        <div class="single_tp p-4 rounded-4 shadow-sm bg-white mb-5" style="border-top: 5px solid #525fe1 !important;">
                            <div class="d-flex align-items-center mb-3">
                                <span class="ti-calendar sc_two me-3" style="font-size: 2rem;"></span>
                                <div>
                                    <h3 class="mb-1">{{ evenement.titre }}</h3>
                                    <p class="text-muted mb-0">
                                        📅 {{ evenement.dateDebut|date('d/m/Y à H:i') }}<br>
                                        📍 {{ evenement.lieu.nom }}, {{ evenement.lieu.ville }}
                                    </p>
                                </div>
                            </div>
                            <div class="mt-3">
                                {% if evenement.prix %}
                                    <span class="h4" style="color: #0b104a; font-weight: 700;">💰 {{ evenement.prix }} €</span>
                                {% else %}
                                    <span class="badge bg-success py-2 px-3">Gratuit</span>
                                {% endif %}
                                <span class="ms-2 text-muted small">| Organisé par {{ evenement.organisateur.pseudo }}</span>
                            </div>
                        </div>

                        {# --- FORMULAIRE D'INSCRIPTION --- #}
                        <div class="contact bg-white p-5 rounded-4 shadow-sm" style="border-top: 5px solid #525fe1 !important;">
                            {{ form_start(formulaire) }}
                                
                                <div class="alert alert-info border-0 rounded-3 mb-4">
                                    <small>Vous êtes connecté en tant que : <strong>{{ app.user.pseudo }}</strong> ({{ app.user.email }})</small>
                                </div>

                                <div class="mb-4">
                                    {# On personnalise l'affichage du champ commentaire #}
                                    {{ form_label(formulaire.commentaire, 'Votre message (optionnel)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                    {{ form_widget(formulaire.commentaire, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Un message ou une question pour l\'organisateur ?'}}) }}
                                    {{ form_errors(formulaire.commentaire) }}
                                </div>

                                <div class="d-flex gap-3 mt-5">
                                    <div class="flex-grow-1">
                                        {# Bouton Valider #}
                                        {{ form_widget(formulaire.enregistrer, {'label': '✅ Confirmer mon inscription', 'attr': {'class': 'btn_one w-100', 'style': 'border:none; height: 50px;'}}) }}
                                    </div>
                                    <div class="flex-grow-1">
                                        <a href="{{ path('app_evenement_detail', {id: evenement.id}) }}" class="header-btn w-100 text-center d-inline-block py-2" style="border: 2px solid #525fe1; border-radius: 50px; height: 50px; line-height: 30px; text-decoration: none;">
                                            ← Annuler
                                        </a>
                                    </div>
                                </div>

                            {# Le form_end affichera automatiquement les champs cachés comme le token CSRF #}
                            {{ form_end(formulaire) }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}