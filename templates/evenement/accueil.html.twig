{% extends 'base.html.twig' %}

{% block title %}🎉 Accueil - Les 2 Mousquetaires{% endblock %}

{% block body %}

<!-- START HOME -->
<section class="home_bg hb_height"
    style="background-image: url({{ asset('assets/img/bg/home-bg.jpg') }}); background-size: cover; background-position: center center; margin-top: -100px; padding-bottom: 100px;">

    <div class="container">
        <div class="row">

            <!-- LEFT -->
            <div class="col-lg-6 col-sm-12">
                <div class="hero-text ht_top">

                    <h1><span>Smart Events</span> Où la passion rencontre l'organisation</h1>

                    <p>
                        Découvrez et participez aux événements les plus intéressants de votre région avec Les 2 Mousquetaires.
                    </p>

                    <!-- RECENTS (1 SEUL BLOC PROPRE) -->
                    {% if recents is defined and recents|length > 0 %}
                        <div class="mt-4">
                            <h4>📋 Derniers événements consultés</h4>

                            <ul>
                                {% for e in recents %}
                                    <li>
                                        <a href="{{ path('app_evenement_detail', {id: e.id}) }}">
                                            {{ e.titre }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                </div>

                <div class="home_sb">
                    <div class="d-flex gap-3 mt-4">

                        <a href="{{ path('app_evenements') }}" class="btn_one">
                            📅 Voir les événements
                        </a>

                        {% if is_granted('ROLE_ORGANISATEUR') %}
                            <a href="{{ path('app_evenement_nouveau') }}"
                               class="header-btn"
                               style="border:2px solid #525fe1; border-radius:50px; padding:15px 30px;">
                                ➕ Créer un événement
                            </a>

                        {% elseif not app.user %}
                            <a href="{{ path('app_register') }}"
                               class="header-btn"
                               style="border:2px solid #525fe1; border-radius:50px; padding:15px 30px;">
                                🚀 Rejoignez-nous
                            </a>
                        {% endif %}

                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-6 col-sm-12">
                <div class="hero-text-img">
                    <img src="{{ asset('assets/img/home-img2.png') }}" class="img-fluid">
                </div>
            </div>

        </div>
    </div>
</section>
<!-- END HOME -->


<!-- COUNTER -->
<section class="count_area counter_feature">
    <div class="container">
        <div class="row">

            <div class="col-lg-3 col-sm-6">
                <h2>{{ evenements|length }}+</h2>
                <p>Événements</p>
            </div>

            <div class="col-lg-3 col-sm-6">
                <h2>10+</h2>
                <p>Lieux</p>
            </div>

            <div class="col-lg-3 col-sm-6">
                <h2>100%</h2>
                <p>Passion</p>
            </div>

            <div class="col-lg-3 col-sm-6">
                <h2>Active</h2>
                <p>Communauté</p>
            </div>

        </div>
    </div>
</section>


<!-- EVENTS -->
<section class="section-padding">
    <div class="container">

        <div class="section-title text-center">
            <h2>📌 Prochains événements</h2>
        </div>

        <div class="row g-4">

            {% for evenement in evenements %}
            
                <div class="col-lg-4 col-md-6">

                    <div class="single_course">

                        <!-- IMAGE -->
                        {% if evenement.imageName %}
                            <img src="/uploads/evenements/{{ evenement.imageName }}" style="width:100%; height:200px; object-fit:cover;">
                        {% else %}
                            <div style="height:200px; display:flex; align-items:center; justify-content:center;">
                                📅
                            </div>
                        {% endif %}

                        <!-- CONTENT -->
                        <div style="padding:20px;">

                            <h4>
                                <a href="{{ path('app_evenement_detail', {id: evenement.id}) }}">
                                    {{ evenement.titre }}
                                </a>
                            </h4>

                            <p>
                                📅  ({{ evenement.dateDebut|time_ago }}) <br>
                                📍 {{ evenement.lieu.nom }} - {{ evenement.lieu.ville }}
                            </p>
                            <!-- PRICE -->
                            <p>{{ evenement.prix|price_format }}</p>
                            {{ capacity_badge(evenement.inscriptions|length, evenement.capaciteMax) }}

                           

                        </div>

                    </div>

                </div>
            {% else %}
                <p class="text-center">Aucun événement</p>
            {% endfor %}

        </div>

    </div>
</section>

{% endblock %}