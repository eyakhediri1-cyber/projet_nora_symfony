{% extends 'base.html.twig' %}

{% block title %}✏️ Modifier : {{ evenement.titre }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4">✏️ Modifier l'événement</h1>
            <p class="text-muted mb-4 pb-2 border-bottom">Modification de « {{ evenement.titre }} »</p>

            {{ form_start(formulaire, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.titre) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.categorie) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_row(formulaire.description) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.dateDebut) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.dateFin) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.lieu) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.capaciteMax) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.prix) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(formulaire.statut) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_row(formulaire.imageName) }}
                </div>

                <div class="mb-3">
                    <label class="form-label">🏷️ Tags</label>
                    <div style="max-height: 150px; overflow-y: auto; border: 1px solid #dee2e6; padding: 10px; border-radius: 4px;">
                        {{ form_widget(formulaire.tags) }}
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    {{ form_row(formulaire.enregistrer) }}
                    <a href="{{ path('app_evenement_detail', {id: evenement.id}) }}" class="btn btn-outline-secondary flex-grow-1">
                        ← Annuler
                    </a>
                </div>

            {{ form_end(formulaire) }}
        </div>
    </div>
{% endblock %}
