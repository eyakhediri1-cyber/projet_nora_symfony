{% extends 'base.html.twig' %}

{% block title %}✏️ Modifier : {{ evenement.titre }} - Les 2 Mousquetaires{% endblock %}

{% block body %}
    <section class="section-padding">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="section-title text-center">
                        <h2>✏️ Modifier l'<b>événement</b></h2>
                        <p>Modification de « <strong>{{ evenement.titre }}</strong> »</p>
                    </div>

                    <div class="contact bg-white p-5 rounded-4 shadow-sm" style="border-top: 5px solid #525fe1 !important;">
                        {{ form_start(formulaire, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                            
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.titre, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.categorie, {'attr': {'class': 'form-select'}}) }}
                                </div>
                            </div>

                            <div class="mb-4">
                                {{ form_row(formulaire.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.dateDebut, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.dateFin, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.lieu, {'attr': {'class': 'form-select'}}) }}
                                </div>
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.capaciteMax, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.prix, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                <div class="col-md-6 mb-4">
                                    {{ form_row(formulaire.statut, {'attr': {'class': 'form-select'}}) }}
                                </div>
                            </div>

                            <div class="mb-4">
                                {{ form_row(formulaire.imageName, {'attr': {'class': 'form-control'}}) }}
                            </div>

                            <div class="mb-4">
                                <label class="form-label h5 mb-3">🏷️ Tags associés</label>
                                <div class="p-4 rounded-3" style="background-color: #f8f9fa; border: 1px solid #eee; max-height: 200px; overflow-y: auto;">
                                    {{ form_widget(formulaire.tags) }}
                                </div>
                            </div>

                            <div class="d-flex gap-3 mt-5">
                                <div class="flex-grow-1">
                                    {{ form_widget(formulaire.enregistrer, {'attr': {'class': 'btn_one w-100', 'style': 'border:none; height: 50px;'}}) }}
                                </div>
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_evenement_detail', {id: evenement.id}) }}" class="header-btn w-100 text-center d-inline-block py-2" style="border: 2px solid #525fe1; border-radius: 50px; height: 50px; line-height: 30px;">
                                        ← Annuler
                                    </a>
                                </div>
                            </div>

                        {{ form_end(formulaire) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
