{% extends 'base.html.twig' %}

{% block title %}➕ Ajouter un lieu - Les 2 Mousquetaires{% endblock %}

{% block body %}
    <section class="section-padding">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="section-title text-center">
                        <h2>➕ Ajouter un <b>lieu</b></h2>
                        <p>Enregistrez un nouvel endroit pour vos futurs événements.</p>
                    </div>

                    <div class="contact bg-white p-5 rounded-4 shadow-sm" style="border-top: 5px solid #525fe1 !important;">
                        {{ form_start(formulaire) }}
                            <div class="mb-4">
                                {{ form_row(formulaire.nom, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="mb-4">
                                {{ form_row(formulaire.adresse, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="mb-4">
                                {{ form_row(formulaire.ville, {'attr': {'class': 'form-control'}}) }}
                            </div>
                            <div class="mb-4">
                                {{ form_row(formulaire.capacite, {'attr': {'class': 'form-control'}}) }}
                            </div>

                            <div class="d-flex gap-3 mt-5">
                                <div class="flex-grow-1">
                                    {{ form_widget(formulaire.enregistrer, {'attr': {'class': 'btn_one w-100', 'style': 'border:none; height: 50px;'}}) }}
                                </div>
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_lieux') }}" class="header-btn w-100 text-center d-inline-block py-2" style="border: 2px solid #525fe1; border-radius: 50px; height: 50px; line-height: 30px;">
                                        ← Annuler
                                    </a>
                                </div>
                            </div>

                        {{ form_end(formulaire) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
