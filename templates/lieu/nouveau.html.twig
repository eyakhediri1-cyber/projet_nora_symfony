{% extends 'base.html.twig' %}

{% block title %}➕ Ajouter un lieu{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <h1 class="mb-4">➕ Ajouter un lieu</h1>

            {{ form_start(formulaire) }}
                <div class="mb-3">
                    {{ form_row(formulaire.nom) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formulaire.adresse) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formulaire.ville) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formulaire.capacite) }}
                </div>

                <div class="d-flex gap-2 mt-4">
                    {{ form_row(formulaire.enregistrer) }}
                    <a href="{{ path('app_lieux') }}" class="btn btn-outline-secondary flex-grow-1">
                        ← Annuler
                    </a>
                </div>

            {{ form_end(formulaire) }}
        </div>
    </div>
{% endblock %}
