{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2 class="fw-bold mb-4">👥 Gestion des utilisateurs</h2>

    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Pseudo</th>
                        <th>Email</th>
                        <th>Rôle actuel</th>
                        <th>Changer le rôle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.pseudo }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge bg-danger">ADMIN</span>
                            {% else %}
                                <span class="badge bg-primary">USER</span>
                            {% endif %}
                        </td>
                        <td>
                            <form method="post" action="{{ path('app_admin_user_role', {id: user.id}) }}" class="d-flex gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('change_role_' ~ user.id) }}">
                                <select name="role" class="form-select form-select-sm" style="width: auto;">
                                    <option value="ROLE_USER" {% if 'ROLE_ADMIN' not in user.roles %}selected{% endif %}>USER</option>
                                    <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in user.roles %}selected{% endif %}>ADMIN</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-warning">Modifier</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}